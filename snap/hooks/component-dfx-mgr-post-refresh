#!/bin/sh
set -eu

# Component post-refresh hook for dfx-mgr
# This hook runs when the dfx-mgr component is updated

CONF_DIR="$SNAP_COMMON/etc/dfx-mgrd"
CONF_FILE="$CONF_DIR/daemon.conf"
DEFAULT_CONF="$SNAP_COMPONENTS/dfx-mgr/daemon.conf"

mkdir -p "$CONF_DIR"

# Only restore the default config if the user's config is missing
if [ ! -f "$CONF_FILE" ]; then
    echo "Restoring default dfx-mgrd daemon.conf"
    cp "$DEFAULT_CONF" "$CONF_FILE"
else
    echo "Preserving existing dfx-mgrd daemon.conf"
    echo "Updated default config available at: $DEFAULT_CONF"
fi

